# Checkmarx One API credentials (required)
CHECKMARX_API_KEY=         # API key (refresh token) from IAM → API Keys
CHECKMARX_TENANT=          # Tenant name

# Regional endpoints (optional — defaults to US region)
CHECKMARX_BASE_URL=https://ast.checkmarx.net    # API base: eu.ast.checkmarx.net, deu.ast.checkmarx.net, etc.
CHECKMARX_IAM_URL=https://iam.checkmarx.net     # IAM base: eu.iam.checkmarx.net, deu.iam.checkmarx.net, etc.

# Default project (optional — tools accept per-call override)
CHECKMARX_PROJECT_ID=      # UUID of the default Checkmarx One project

# Transport configuration (optional)
TRANSPORT=stdio            # "stdio" for CLI clients (Claude Code, Cursor) or "http" for remote/shared
PORT=3000                  # Port for HTTP transport
