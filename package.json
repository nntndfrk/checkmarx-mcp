{
  "name": "@nntndfrk/checkmarx-mcp",
  "version": "0.2.0",
  "description": "MCP server providing AI coding agents with full programmatic access to the Checkmarx One security platform",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "server.json"
  ],
  "bin": {
    "checkmarx-mcp": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node scripts/add-shebang.mjs",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.tests.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "checkmarx",
    "security",
    "sast",
    "sca",
    "vulnerability",
    "ai",
    "claude",
    "cursor"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nntndfrk/checkmarx-mcp.git"
  },
  "homepage": "https://github.com/nntndfrk/checkmarx-mcp#readme",
  "bugs": {
    "url": "https://github.com/nntndfrk/checkmarx-mcp/issues"
  },
  "author": "Mykhailo Smolinskyi <nntndfrk@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "~1.27.1",
    "archiver": "^7.0.1",
    "express": "^5.1.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/archiver": "^7.0.0",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
