{
  "name": "@nntndfrk/checkmarx-mcp",
  "version": "0.1.2",
  "description": "MCP server providing AI coding agents with full programmatic access to the Checkmarx One security platform",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "bin": {
    "checkmarx-mcp": "dist/index.js"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target node && node -e \"const fs=require('fs'),p='dist/index.js';fs.writeFileSync(p,'#!/usr/bin/env node\\n'+fs.readFileSync(p,'utf8'));\"",
    "start": "node dist/index.js",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "mcp",
    "checkmarx",
    "security",
    "sast",
    "sca",
    "vulnerability",
    "ai",
    "claude",
    "cursor"
  ],
  "author": "Mykhailo Smolinskyi <nntndfrk@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "archiver": "^7.0.1",
    "express": "^5.1.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/archiver": "^7.0.0",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.3"
  }
}
